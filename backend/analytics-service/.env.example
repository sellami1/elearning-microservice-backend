# Analytics service runtime
ANALYTICS_BACKEND_ENV=dev
ANALYTICS_BACKEND_APP_NAME=Analytics Service
ANALYTICS_BACKEND_LOG_LEVEL=DEBUG
ANALYTICS_BACKEND_PORT=8003

# Database
ANALYTICS_BACKEND_POSTGRES_URL=postgresql://course_user:course_password@course-postgres:5432/course_db

# Auth
ANALYTICS_BACKEND_JWT_SECRET_KEY=change-me-analytics-secret
ANALYTICS_BACKEND_JWT_ALGORITHM=HS256

# Redis
ANALYTICS_BACKEND_REDIS_HOST=redis
ANALYTICS_BACKEND_REDIS_PORT=6379
ANALYTICS_BACKEND_REDIS_TTL_SECONDS=60
