# Database
COURSE_BACKEND_POSTGRES_URL=postgresql://user:password@postgres:5432/course_db

# JWT
COURSE_BACKEND_JWT_SECRET_KEY=your-secret-key-here-change-in-production
COURSE_BACKEND_JWT_ALGORITHM=HS256
COURSE_BACKEND_ACCESS_TOKEN_EXPIRE_MINUTES=30

# MinIO
COURSE_BACKEND_MINIO_ENDPOINT=minio:9000
COURSE_BACKEND_MINIO_ACCESS_KEY=minioadmin
COURSE_BACKEND_MINIO_SECRET_KEY=minioadmin
COURSE_BACKEND_MINIO_BUCKET_NAME=courses-media
COURSE_BACKEND_MINIO_SECURE=False

# Analytics
COURSE_BACKEND_ANALYTICS_URL=http://localhost:8003
COURSE_BACKEND_ANALYTICS_REQUEST_TIMEOUT_SECONDS=2.0

# App
COURSE_BACKEND_ENV=dev
COURSE_BACKEND_APP_NAME="Course Service"
COURSE_BACKEND_APP_VERSION="1.0.0"
COURSE_BACKEND_LOG_LEVEL=DEBUG
COURSE_BACKEND_DEBUG=True
COURSE_BACKEND_PORT=8001