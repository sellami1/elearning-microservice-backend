APP_NAME=Learning Portal

NODE_ENV=dev
FRONTEND_NODE_ENV=production
FRONTEND_PORT=3000
FRONTEND_API_URL=http://192.168.1.12

MONGO_INITDB_DATABASE=user_service_db
POSTGRES_USER=course_user
POSTGRES_PASSWORD=course_password
POSTGRES_DB=course_db
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

USER_BACKEND_ENV=dev
USER_BACKEND_PORT=8002
USER_BACKEND_URL=http://localhost:8002
USER_BACKEND_PUBLIC_FRONTEND_URL=http://localhost:3000
USER_BACKEND_JWT_SECRET_KEY=change-me-shared-jwt-secret
USER_BACKEND_JWT_EXPIRE_TIME=1d
USER_BACKEND_MONGODB_URI=mongodb://mongodb:27017/user_service_db
USER_BACKEND_APP_NAME=E-learning User Service
USER_BACKEND_EMAIL_PORT=1025
USER_BACKEND_EMAIL_SECURE=false
USER_BACKEND_EMAIL_FROM=no-reply@local.test
USER_BACKEND_EMAIL_USER=
USER_BACKEND_EMAIL_PASSWORD=

COURSE_BACKEND_ENV=dev
COURSE_BACKEND_LOG_LEVEL=DEBUG
COURSE_BACKEND_PORT=8001
COURSE_BACKEND_POSTGRES_URL=postgresql://course_user:course_password@course-postgres:5432/course_db
COURSE_BACKEND_JWT_SECRET_KEY=change-me-shared-jwt-secret
COURSE_BACKEND_JWT_ALGORITHM=HS256
COURSE_BACKEND_ACCESS_TOKEN_EXPIRE_MINUTES=30
COURSE_BACKEND_MINIO_ENDPOINT=minio:9000
COURSE_BACKEND_MINIO_PUBLIC_URL=http://localhost/media
COURSE_BACKEND_MINIO_ACCESS_KEY=minioadmin
COURSE_BACKEND_MINIO_SECRET_KEY=minioadmin
COURSE_BACKEND_MINIO_BUCKET_NAME=courses-media
COURSE_BACKEND_MINIO_SECURE=False
COURSE_BACKEND_ANALYTICS_URL=http://analytics-service:8003
COURSE_BACKEND_ANALYTICS_REQUEST_TIMEOUT_SECONDS=2.0
COURSE_BACKEND_APP_NAME=Course Service
COURSE_BACKEND_APP_VERSION=1.0.0
COURSE_BACKEND_DEBUG=True

ANALYTICS_BACKEND_ENV=dev
ANALYTICS_BACKEND_APP_NAME=Analytics Service
ANALYTICS_BACKEND_LOG_LEVEL=DEBUG
ANALYTICS_BACKEND_PORT=8003
ANALYTICS_BACKEND_POSTGRES_URL=postgresql://course_user:course_password@course-postgres:5432/course_db
ANALYTICS_BACKEND_JWT_SECRET_KEY=change-me-analytics-secret
ANALYTICS_BACKEND_JWT_ALGORITHM=HS256
ANALYTICS_BACKEND_REDIS_HOST=redis
ANALYTICS_BACKEND_REDIS_PORT=6379
ANALYTICS_BACKEND_REDIS_TTL_SECONDS=60
